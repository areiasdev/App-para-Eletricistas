# Copy to docker-compose.prod.env and fill in real values.
# docker-compose.prod.env is gitignored — never commit secrets.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_random_password

# ── JWT (minimum 32 chars, generated randomly) ───────────────────────────────
JWT_SECRET=change_me_use_openssl_rand_hex_32
JWT_ISSUER=https://tecnicoapp.pt
JWT_AUDIENCE=https://tecnicoapp.pt
JWT_EXPIRY_MINUTES=60

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL where the frontend is hosted (used in CORS and password-reset emails)
FRONTEND_URL=https://app.tecnicoapp.pt
# Public URL of the API (baked into the Next.js bundle at build time)
NEXT_PUBLIC_API_URL=https://api.tecnicoapp.pt

# ── SMTP (leave blank in dev — emails are logged to console instead) ──────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=postmaster@mg.tecnicoapp.pt
SMTP_PASSWORD=change_me
SMTP_FROM_NAME=TécnicoApp
SMTP_FROM_ADDRESS=noreply@tecnicoapp.pt

# ── Stripe (leave blank until Stripe is wired up) ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...
